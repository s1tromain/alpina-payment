# === Telegram Bots (two separate bots) ===
MOD_BOT_TOKEN=your_moderator_bot_token
USER_BOT_TOKEN=your_user_bot_token

# === Webhook Secrets (any random string, different for each bot) ===
MOD_WEBHOOK_SECRET=your_mod_webhook_secret
USER_WEBHOOK_SECRET=your_user_webhook_secret

# === Telegram Channel & Admin ===
CHANNEL_ID=-100xxxxxxxxxx
ADMIN_ID=123456789

# === Moderation ===
MODERATOR_PASSWORD=your_password_here

# === Site / Mini App ===
SITE_URL=https://your-project.vercel.app
MINI_APP_URL=https://your-project.vercel.app

# Supabase / Postgres (optional, not used in Redis-only mode)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN= 

# Rate Source (Rapira)
RAPIRA_API_URL=https://rapira.net/api/rate?pair=USDT_RUB

# Markup on rate (percent)
MARKUP_PERCENT=8

# Payment requisites shown to user (bank card / details for RUB payment)
PAYMENT_REQUISITES=7777 7777 7777 7777

# Cron secret (for Vercel Cron job, optional)
CRON_SECRET=
