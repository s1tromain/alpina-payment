# Rate Source (Rapira)
RAPIRA_API_URL=https://rapira.net/api/rate?pair=USDT_RUB

# Markup on rate (percent)
MARKUP_PERCENT=8

# Payment requisites shown to user (bank card / details for RUB payment)
PAYMENT_REQUISITES=7777 7777 7777 7777

# Cron secret (for Vercel Cron job, optional)
CRON_SECRET=
